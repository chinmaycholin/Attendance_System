# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environment (too large to push, run setup.py instead)
packages/Lib/
packages/Include/
packages/Scripts/
packages/pyvenv.cfg

# Keep the DNN model files inside packages/
!packages/deploy.prototxt
!packages/res10_300x300_ssd_iter_140000.caffemodel

# Encodings (generated by train.py — too large / user-specific)
encodings.pkl

# Processed training images (generated by train.py)
processed/

# Dataset images (private / too large)
dataset/

# Attendance log (user-specific)
attendance.csv

# Runtime config — stores your local IP camera URL, not for others
settings.json

# Redundant Pyright config (replaced by .vscode/settings.json)
pyrightconfig.json

# VS Code — keep settings.json so the interpreter is auto-selected
.vscode/*
!.vscode/settings.json

# Misc
*.log
Thumbs.db
.DS_Store
